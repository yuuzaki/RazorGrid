@page "/change-password"
@inject HttpClient Http
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject BlazorGrid.Services.QueryParamProtector Protector
@using System.ComponentModel.DataAnnotations

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-sm w-100" style="max-width:400px">
        <h1 class="text-center fw-bold mb-2">AUTH APP</h1>
        @if(! isWaitingProcess){
            <h4 class="text-center mb-3">Update Password</h4>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (isWaitingProcess)
        {
            <div class="slide-from-right">
                <h4 class="text-center mb-3">Processing</h4>
                <div class="text-center">
                    <div class="spinner-border mb-3"></div>
                    @if (waitingProcessResult)
                    {
                        <p>@((MarkupString)waitingLine1)</p>
                        <p>@((MarkupString)waitingLine2)</p>
                    }
                    else
                    {
                        <p>Sending request <span class="dots"></span></p>
                    }
                </div>
            </div>
        }
        else if (!tokenValid)
        {
            <div class="slide-from-right">
                <div class="alert alert-danger">Invalid or expired link. Please login again.</div>
                <a class="btn btn-secondary w-100" href="/login">Back to Login</a>
            </div>
        }
        else
        {
            <div class="slide-from-right">
                <EditForm Model="model" OnValidSubmit="HandleChangePassword" FormName="ChangePassword">
                    <DataAnnotationsValidator />

                    <div class="mb-2">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" value="@username"
                               disabled autocomplete="username" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Current Password</label>
                        <InputText type="password" class="form-control" @bind-Value="model.Password"
                                   placeholder="Current password" autocomplete="current-password" />
                        <ValidationMessage For="@(() => model.Password)" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">New Password</label>
                        <InputText type="password" class="form-control" @bind-Value="model.NewPassword"
                                   placeholder="New password" autocomplete="new-password" />
                        <ValidationMessage For="@(() => model.NewPassword)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirm New Password</label>
                        <InputText type="password" class="form-control" @bind-Value="model.ConfirmNewPassword"
                                   placeholder="Confirm new password" autocomplete="new-password" />
                        <ValidationMessage For="@(() => model.ConfirmNewPassword)" />
                    </div>

                    <button class="btn btn-primary w-100" type="submit">Update Password</button>
                </EditForm>
                <div class="text-center mt-3">
                    <a href="/login" class="text-decoration-none small">Back to Login</a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ChangePasswordModel model = new();
    private string? errorMessage;
    private string username = string.Empty;
    private string redirectUrl = "/";
    private bool tokenValid = false;
    private bool isWaitingProcess = false;
    private bool waitingProcessResult = false;
    private string waitingLine1 = string.Empty;
    private string waitingLine2 = string.Empty;

    protected override void OnInitialized()
    {
        tokenValid = Protector.TryUnprotect(Token, out username, out redirectUrl);
    }

    private async Task HandleChangePassword()
    {
        if (model.NewPassword != model.ConfirmNewPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        errorMessage = string.Empty;

        // var payload = new { Username = username, OldPassword = model.Password, NewPassword = model.NewPassword };
        // var response = await Http.PostAsJsonAsync("api/auth/change-password", payload);

        isWaitingProcess = true;
        StateHasChanged();
        await Task.Delay(1300);
        waitingProcessResult = true;
        waitingLine1 = "Password updated successfully!";
        waitingLine2 = "Redirecting to login <span class=\"dots\"></span>";
        StateHasChanged();
        await Task.Delay(1300);
        NavigationManager.NavigateTo($"/login?redirectUrl={Uri.EscapeDataString(redirectUrl)}");
    }

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Current password is required")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "New password is required")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your new password")]
        public string ConfirmNewPassword { get; set; } = string.Empty;
    }
}
