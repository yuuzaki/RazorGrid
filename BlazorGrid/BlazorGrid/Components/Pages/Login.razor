@page "/login"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations;
<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-sm w-100" style="max-width:400px">

        
        <h1 class="bbl-f-c text-center fw-bold mb-2">BBL IDP</h1>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        @if (isWaiting2FA)
        {
            <h4 class="text-center mb-3">Login in process<span class="dots"></span></h4>
            <div class="text-center">
                <div class="spinner-border text-primary mb-3"></div>
                @if (!approved2FA)
                {
                    <p>Please approve login on your mobile app <span class="dots"></span></p>
                }
                else
                {
                    <p>2 FA Approved redirect <span class="dots"></span></p>
                }
            </div>
            
        }
        else if (isWaitingProcess)
        {
            <h4 class="text-center mb-3">Processing</h4>
            <div class="text-center">
                <div class="spinner-border text-primary mb-3"></div>
                @if (waitingProcessResult)
                {
                    <p>@((MarkupString)waitingLine1)</p>
                    <p>@((MarkupString)waitingLine2)</p>

                }
                else
                {
                    <p>Sending request <span class="dots"></span></p>
                }
            </div>
        }
        else if (isChangePassword)
        {
            <h4 class="text-center mb-3">Update Password</h4>
            <EditForm Model="changePasswordModel" OnValidSubmit="ResetPassword" FormName="ResetPassword">
                <DataAnnotationsValidator />
                <div>
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control mb-2" @bind-Value="changePasswordModel.Password" placeholder="New Password" />
                    <label class="form-label">New Password</label>
                    <InputText type="password" class="form-control mb-2" @bind-Value="changePasswordModel.NewPassword" placeholder="New Password" />
                    <label class="form-label">Reconfirm New Password</label>
                    <InputText type="password" class="form-control mb-2" @bind-Value="changePasswordModel.ConfirmNewPassword" placeholder="New Password" />
                    <button class="btn btn-primary w-100" >Reset Password</button>
                </div>
            </EditForm>
        }
        else if (isUnactivatedUser)
        {
            <EditForm Model="loginModel" OnValidSubmit="ActivateResetPassword" FormName="Activate_ResetPassword">
                <DataAnnotationsValidator />
                <h4 class="text-center mb-3">User Activation</h4> <div>
                    <label class="form-label">New Password</label>
                    <InputText type="password" class="form-control mb-2" @bind-Value="resetPasswordModel.NewPassword" placeholder="New Password" />
                    <label class="form-label">Reconfirm New Password</label>
                    <InputText type="password" class="form-control mb-2" @bind-Value="resetPasswordModel.ConfirmNewPassword" placeholder="New Password" />
                    <button class="btn btn-primary w-100" >Reset Password</button>
                </div>
            </EditForm>
        }
        
        else
        {
            <h4 class="text-center mb-3">Login</h4>
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="Login">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText class="form-control" @bind-Value="loginModel.Username" />
                    <ValidationMessage For="@(() => loginModel.Username)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText type="password" class="form-control" @bind-Value="loginModel.Password" />
                    <ValidationMessage For="@(() => loginModel.Password)" />
                </div>

                <button class="btn btn-primary w-100" type="submit">
                    Login
                </button>

            </EditForm>
        
        }
    </div>
</div>


@code {
    private LoginModel loginModel = new();
    private ResetPasswordModel resetPasswordModel = new();
    private ChangePasswordModel changePasswordModel = new();
    private string errorMessage;

    private string waitingLine1 = String.Empty;
    private string waitingLine2 = String.Empty;

    private bool isWaiting2FA = false;
    private bool approved2FA = false;

    private bool isWaitingProcess = false;
    private bool waitingProcessResult = false;

    private bool isChangePassword = false;
    private bool isUnactivatedUser = false;

    private bool isSetQA = false;

    private string transactionId;

    protected void ToggleTable()
    {
        approved2FA = !approved2FA;

    }
    protected async Task HandleLogin()
    {
        errorMessage = "";

        //var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
        //var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
        Thread.Sleep(200);
        var result = new loginResponseModel();
        if (loginModel.Password.StartsWith("e"))
        {
            result.Status = "PASSWORD_EXPIRED";
        }
        else if (loginModel.Password.StartsWith("u"))
        {
            result.Status = "UNACTIVATE";
        }
        else if (!loginModel.Password.Contains("Password123"))
        {
            result.Status = "INVALID";
        }
        else
        {
            result.Status = "REQUIRES_2FA";
        }
        switch (result.Status)
        {
            case "UNACTIVATE":
                isUnactivatedUser = true;
                break;
            case "SUCCESS":
                NavigateToHome();
                break;

            case "INVALID":
                errorMessage = "Invalid username or password";
                break;

            case "PASSWORD_EXPIRED":
                isChangePassword = true;
                break;

            case "REQUIRES_2FA":
                isWaiting2FA = true;
                transactionId = result.TransactionId;
                await Task.Delay(2000);
                approved2FA = true;
                StateHasChanged();
                await Task.Delay(2000);

                NavigateToHome();
                break;
        }
    }

    private async Task ResetPassword()
    {
        if (resetPasswordModel.NewPassword == resetPasswordModel.ConfirmNewPassword)
        {
            isChangePassword = false;
            isWaitingProcess = true;
            StateHasChanged();
            await Task.Delay(1300);
            waitingProcessResult = true;
            waitingLine1 = "Successfully update your password!"; 
            waitingLine2 = "Redirect to login <span class=\"dots\"></span>";
            StateHasChanged();
            await Task.Delay(1300);
            //errorMessage = "Password updated. Please login again.";
            NavigateToLogin();
        }
        else
        {
            errorMessage = "Recheck password";
        }
    }
    private async Task ActivateResetPassword()
    {
        if (resetPasswordModel.NewPassword == resetPasswordModel.ConfirmNewPassword)
        {
            isUnactivatedUser = false;
            isWaitingProcess = true;
            //show update card
            StateHasChanged();
            await Task.Delay(1500);
            //update result 
            waitingProcessResult = true; 
            waitingLine1 = "Successfully update your password!";
            waitingLine2 = "Redirect to Set Recovery questions <span class=\"dots\"></span>";
            StateHasChanged();
            await Task.Delay(1500);
            isSetQA = true;
            StateHasChanged();
            //errorMessage = "Password updated. Please login again.";
            //NavigateToLogin();
        }
        else
        {
            errorMessage = "Recheck password";
        }
    }
   
    private async Task Poll2FA()
    {
        while (isWaiting2FA)
        {

            //var result = await Http.GetFromJsonAsync<AuthResponse>(
            //   $"api/auth/2fa-status/{transactionId}");
            var result = new loginResponseModel()
                {
                    Status = "APPROVED"
                };
            if (result.Status == "APPROVED")
            {
                await Task.Delay(2000);
                isWaiting2FA = false;
                StateHasChanged();
                await Task.Delay(1000);
                //await InvokeAsync(() => NavigationManager.NavigateTo("/Weather",true));

                break;
            }
            else if (result.Status == "REJECTED")
            {
                isWaiting2FA = false;
                errorMessage = "2FA request rejected";
                break;
            }
        }
    }
    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/Login",true);
    }
    private void NavigateToHome()
    {
        NavigationManager.NavigateTo("/Weather");
    }

    public class loginResponseModel
    {
        public String Status { get; set; } = "SUCCESS";
        public String TransactionId { get; set; }
    }
    public class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; }
        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; }
    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "Password is required")]
        public string NewPassword { get; set; }
        [Required(ErrorMessage = "Password is required")]
        public string ConfirmNewPassword { get; set; }
    }
    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; }
        [Required(ErrorMessage = "Password is required")]
        public string NewPassword { get; set; }
        [Required(ErrorMessage = "Password is required")]
        public string ConfirmNewPassword { get; set; }
    }
    public class AuthResponse
    {
        public string Status { get; set; }
        public string TransactionId { get; set; }
    }
   
}