@page "/login"
@inject HttpClient Http
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject BlazorGrid.Services.QueryParamProtector Protector
@using System.ComponentModel.DataAnnotations


<div class="auth-card">
    <h1 class="app-title">AUTH APP</h1>

    @if (isWaiting2FA)
    {
        <div class="slide-from-right text-center">
            <h2 class="section-title">Login in process</h2>
            <div class="spinner"></div>
            @if (!approved2FA)
            {
                <p>Please approve login on your mobile app <span class="dots"></span></p>
            }
            else
            {
                <p>2FA Approved, redirecting <span class="dots"></span></p>
            }
        </div>
    }
    else
    {
        <div class="slide-from-right">
            <h2 class="section-title">Login</h2>

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="Login">
                <DataAnnotationsValidator />

                <div class="field-wrapper">
                    <input type="text" id="login-username" class="field-input"
                            placeholder=" " @bind="loginModel.Username"
                            autocomplete="username" />
                    <label class="field-label" for="login-username">Username</label>
                    <ValidationMessage For="@(() => loginModel.Username)" />
                </div>

                <div class="field-wrapper" style="margin-bottom:1.75rem;">
                    <input type="password" id="login-password"
                            class="field-input" placeholder=" "
                            @bind="loginModel.Password"
                            autocomplete="current-password" />
                    <label class="field-label" for="login-password">Password</label>
                    <ValidationMessage For="@(() => loginModel.Password)" />
                </div>
                <button disabled =@logingIn class="auth-btn">Login</button>
                
            </EditForm>

            <p class="text-center" style="margin:0;">
                <a href="/forgot-password" class="auth-link">Forgot password?</a>
            </p>
        </div>
    }
</div>

@if (_toastMsg is not null)
{
    <div class="app-toast app-toast--@_toastType">
        <span>@_toastMsg</span>
        <button class="app-toast-close" @onclick="@(() => _toastMsg = null)">&times;</button>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "redirectUrl")]
    public string? RedirectUrl { get; set; }

    private LoginModel loginModel = new();
    private bool isWaiting2FA, approved2FA = false;
    private bool logingIn = false;
    private string? transactionId;

    private string? _toastMsg;
    private string _toastType = "error";
    private void ShowToast(string msg, string type = "error") { _toastMsg = msg; _toastType = type; }
   
    private void ClearToast() => _toastMsg = null;
    protected async Task HandleLogin()
    {
        ClearToast();
        logingIn = true;
        StateHasChanged();
        await Task.Yield();
        try{
            // var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            // var result = await response.Content.ReadFromJsonAsync<LoginResponseModel>();
            Thread.Sleep(1500);
            var result = new LoginResponseModel();
            if (loginModel.Password.StartsWith("e"))
                result.Status = "PASSWORD_EXPIRED";
            else if (loginModel.Password.StartsWith("u"))
                result.Status = "UNACTIVATE";
            else if (!loginModel.Password.Contains("Password123"))
                result.Status = "INVALID";
            else
                result.Status = "REQUIRES_2FA";

            var token = Uri.EscapeDataString(Protector.Protect(loginModel.Username, "/login2" ?? "/"));

            switch (result.Status)
            {
                case "SUCCESS":
                    NavigationManager.NavigateTo(RedirectUrl ?? "/");
                    break;

                case "INVALID":
                    ShowToast("Invalid username or password");
                    break;

                case "PASSWORD_EXPIRED":
                    NavigationManager.NavigateTo($"/change-password?token={token}");
                    break;

                case "UNACTIVATE":
                    NavigationManager.NavigateTo($"/reset-password?token={token}");
                    break;

                case "REQUIRES_2FA":
                    isWaiting2FA = true;
                    await mockAuth();
                    transactionId = result.TransactionId;
                    await Task.Delay(7000);
                    approved2FA = true;
                    StateHasChanged();
                    await Task.Delay(2000);
                    NavigationManager.NavigateTo(RedirectUrl ?? "/");
                    break;
            }
            logingIn = false;
            StateHasChanged();
        }
        catch(Exception ex){
            ShowToast("An error occurred during login. Please try again.");
            logingIn = false;
        }
    }
    public static async Task  mockAuth(){
        using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(12));

        while (!cts.Token.IsCancellationRequested)
        {
            var approved = true;//await Task.Delay(3000)//CheckTwoFactorStatusAsync();
            if (approved) break;
            await Task.Delay(1500, cts.Token); // poll every 1.5s
        }

    }
    public class LoginResponseModel
    {
        public string Status { get; set; } = "SUCCESS";
        public string? TransactionId { get; set; }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
