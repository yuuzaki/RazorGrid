@page "/reset-password"
@inject HttpClient Http
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject BlazorGrid.Services.QueryParamProtector Protector
@using System.ComponentModel.DataAnnotations

<div class="auth-card">
    <h1 class="app-title">AUTH APP</h1>

    @if (isWaitingProcess)
    {
        <div class="slide-from-right text-center">
            <h2 class="section-title">Processing</h2>
            <div class="spinner"></div>
            @if (waitingProcessResult)
            {
                <p>@((MarkupString)waitingLine1)</p>
                <p>@((MarkupString)waitingLine2)</p>
            }
            else
            {
                <p>Sending request <span class="dots"></span></p>
            }
        </div>
    }
    else if (!tokenValid)
    {
        <div class="slide-from-right">
            <div class="auth-alert auth-alert--error">
                Invalid or expired link. Please login again.
            </div>
            <a href="/login" class="auth-btn-ghost">Back to Login</a>
        </div>
    }
    else
    {
        <div class="slide-from-right">
            <h2 class="section-title">Account Activation</h2>

            <EditForm Model="model" OnValidSubmit="HandleActivation" FormName="ResetPassword">
                <DataAnnotationsValidator />

                <div class="field-wrapper">
                    <input type="text" id="rp-username" class="field-input"
                            placeholder=" " value="@username"
                            disabled autocomplete="username" />
                    <label class="field-label" for="rp-username">Username</label>
                </div>

                <div class="field-wrapper">
                    <input type="password" id="rp-new-pw"
                            class="field-input" placeholder=" "
                            @bind="model.NewPassword"
                            autocomplete="new-password" />
                    <label class="field-label" for="rp-new-pw">New Password</label>
                    <ValidationMessage For="@(() => model.NewPassword)" />
                </div>

                <div class="field-wrapper" style="margin-bottom:1.75rem;">
                    <input type="password" id="rp-confirm-pw"
                            class="field-input" placeholder=" "
                            @bind="model.ConfirmNewPassword"
                            autocomplete="new-password" />
                    <label class="field-label" for="rp-confirm-pw">Confirm New Password</label>
                    <ValidationMessage For="@(() => model.ConfirmNewPassword)" />
                </div>

                <button disabled=@isValidatingInput type="submit" class="auth-btn">Activate Account</button>
            </EditForm>

            <p class="text-center" style="margin:0;">
                <a href="/login" class="auth-link">Back to Login</a>
            </p>
        </div>
    }
</div>

@if (_toastMsg is not null)
{
    <div class="app-toast app-toast--@_toastType">
        <span>@_toastMsg</span>
        <button class="app-toast-close" @onclick="@(() => _toastMsg = null)">&times;</button>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ResetPasswordModel model = new();
    private string username = string.Empty;
    private string redirectUrl = "/";
    private bool tokenValid = false;
    private bool isWaitingProcess, waitingProcessResult = false;
    private bool isValidatingInput = false;
    private string waitingLine1 = string.Empty;
    private string waitingLine2 = string.Empty;

    private string? _toastMsg;
    private string _toastType = "error";
    private void ShowToast(string msg, string type = "error") { _toastMsg = msg; _toastType = type; }

    protected override void OnInitialized()
    {
        tokenValid = Protector.TryUnprotect(Token, out username, out redirectUrl);
    }

    private async Task HandleActivation()
    {
        isValidatingInput = true;
        StateHasChanged();
        await Task.Yield();
        if (model.NewPassword != model.ConfirmNewPassword)
        {
            await Task.Delay(500);
            ShowToast("Passwords do not match");
            isValidatingInput = false;
            return;
        }

        // var payload = new { Username = username, NewPassword = model.NewPassword };
        // var response = await Http.PostAsJsonAsync("api/auth/activate", payload);

        isWaitingProcess = true;
        StateHasChanged();
        await Task.Delay(1500);
        waitingProcessResult = true;
        waitingLine1 = "Account activated successfully!";
        waitingLine2 = "Redirecting to login <span class=\"dots\"></span>";
        StateHasChanged();
        await Task.Delay(1500);
        NavigationManager.NavigateTo($"/login?redirectUrl={Uri.EscapeDataString(redirectUrl)}");
    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "New password is required")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmNewPassword { get; set; } = string.Empty;
    }
}
