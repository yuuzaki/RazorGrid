@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card" style="max-width:540px;">
        <h1 style="color:var(--error-title); font-weight:700; font-size:1.8rem; margin:0 0 0.5rem;">Error</h1>
        <p style="color:var(--error-title); margin:0 0 1rem;">An error occurred while processing your request.</p>
        <hr class="auth-divider" />
        @if (ShowRequestId)
        {
            <div class="auth-alert auth-alert--warning" style="margin-bottom:1rem;">
                <strong>Request ID:</strong> <code>@RequestId</code>
            </div>
        }
        <p style="font-weight:600; margin:0 0 0.5rem; color:var(--text-primary);">Development Mode</p>
        <p style="color:var(--text-secondary); font-size:0.9rem; margin:0 0 0.5rem;">
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p style="color:var(--text-secondary); font-size:0.9rem; margin:0;">
            Set <strong>ASPNETCORE_ENVIRONMENT</strong> to <strong>Development</strong> and restart the app.
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);
    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
