@page "/forgot-password"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject BlazorGrid.Services.QueryParamProtector Protector
@inject NavigationManager NavigationManager

<div class="auth-page-wrapper">
    <div class="auth-card">
        <h1 class="app-title">AUTH APP</h1>

        @if (isVerifying)
        {
            <div class="slide-from-right text-center">
                <h2 class="section-title">Processing</h2>
                <div class="spinner"></div>
                @if (verifyResult)
                {
                    <p>@((MarkupString)verifyLine1)</p>
                    <p>@((MarkupString)verifyLine2)</p>
                }
                else
                {
                    <p>Sending request <span class="dots"></span></p>
                }
            </div>
        } 
        else if (!tokenValid)
        {
            <div class="slide-from-right">
                <div class="auth-alert auth-alert--error">
                    Invalid or expired link. Please login again.
                </div>
                <a href="/login" class="auth-btn-ghost">Back to Login</a>
            </div>
        }
        else
        {
            <div class="slide-from-right">
                <h2 class="section-title">Forgot Password</h2>

                <div class="field-wrapper" style="margin-bottom:1.75rem;">
                    <input type="tel" inputmode="numeric" pattern="[0-9]*" maxlength="6"
                           id="otp-input" class="field-input field-input--otp"
                           placeholder=" " value="@otpValue"
                           @oninput="OnOtpInput"
                           autocomplete="one-time-code" />
                    <label class="field-label" for="otp-input">Enter OTP</label>
                </div>

                <button class="auth-btn" disabled="@(isSending || countdown > 0)" @onclick="SendOTPApi">
                    @if (isSending)
                    {
                        <span class="btn-spinner"></span>
                        @("Sending...")
                    }
                    else if (countdown > 0)
                    {
                        @($"...send again in {countdown}s")
                    }
                    else
                    {
                        @("Send OTP")
                    }
                </button>

                <button class="auth-btn" disabled="@isVerifyLoading" @onclick="VerifyOTP">
                    @if (isVerifyLoading)
                    {
                        <span class="btn-spinner"></span>
                        @("Verifying...")
                    }
                    else
                    {
                        @("Verify OTP")
                    }
                </button>

                <p class="text-center" style="margin:0;">
                    <a href="/login" class="auth-link">Back to Login</a>
                </p>
            </div>
        }
    </div>
</div>

@if (_toastMsg is not null)
{
    <div class="app-toast app-toast--@_toastType">
        <span>@_toastMsg</span>
        <button class="app-toast-close" @onclick="@(() => _toastMsg = null)">&times;</button>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }
    private string username = string.Empty;
    private string redirectUrl = "/";

    private string otpValue = string.Empty;
    private bool isSending = false;
    private bool isVerifyLoading = false;
    private int countdown = 0;

    private bool tokenValid = false;
    private bool isVerifying = false;
    private bool verifyResult = false;
    private string verifyLine1 = string.Empty;
    private string verifyLine2 = string.Empty;

    private string? _toastMsg;
    private string _toastType = "error";
    private void ShowToast(string msg, string type = "error") { _toastMsg = msg; _toastType = type; }

    protected override void OnInitialized()
    {
        tokenValid = Protector.TryUnprotect(Token, out username, out redirectUrl);
    }
    private void OnOtpInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        otpValue = new string(raw.Where(char.IsDigit).Take(6).ToArray());
    }

    private async Task SendOTPApi()
    {
        @* if (string.IsNullOrWhiteSpace(otpValue) || otpValue.Length < 6)
        {
            ShowToast("Please enter a valid 6-digit OTP", "warning");
            return;
        } *@

        isSending = true;
        StateHasChanged();

        await Task.Delay(1500);

        isSending = false;
        StateHasChanged();

        _ = RunCountdown();
    }

    private async Task RunCountdown()
    {
        for (countdown = 20; countdown >= 1; countdown--)
        {
            StateHasChanged();
            await Task.Delay(1000);
        }
        countdown = 0;
        StateHasChanged();
    }

    private async Task VerifyOTP()
    {
        if (string.IsNullOrWhiteSpace(otpValue) || otpValue.Length < 6)
        {
            ShowToast("Please enter a valid 6-digit OTP", "warning");
            return;
        }

        isVerifyLoading = true;
        StateHasChanged();

        await Task.Delay(2000);

        isVerifyLoading = false;
        isVerifying = true;
        StateHasChanged();

        await Task.Delay(1500);

        if (otpValue == "666666")
        {
            verifyResult = true;
            verifyLine1 = "OTP verified successfully!";
            verifyLine2 = "Redirecting to login <span class=\"dots\"></span>";
            StateHasChanged();
            await Task.Delay(1500);
            NavigationManager.NavigateTo(redirectUrl);
        }
        else
        {
            isVerifying = false;
            ShowToast("Invalid OTP. Please try again.");
        }
    }
}
