@page "/forgot-password"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-sm w-100" style="max-width:400px">
        <h1 class="text-center fw-bold mb-2">AUTH APP</h1>

        <div class="slide-from-right">
            <h4 class="text-center mb-3">Forgot Password</h4>

            <div class="mb-3">
                <label class="form-label">Enter OTP</label>
                <input type="text"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       maxlength="6"
                       class="form-control otp-input"
                       @bind="otpValue"
                       @bind:event="oninput"
                       placeholder="000000" />
            </div>

            <button class="btn btn-primary w-100"
                    @onclick="SendOTPApi"
                    disabled="@isSending">
                @(isSending ? "Sending..." : "Send OTP")
            </button>

            <div class="text-center mt-3">
                <a href="/login" class="text-decoration-none small">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string otpValue = string.Empty;
    private bool isSending = false;

    private async Task SendOTPApi()
    {
        isSending = true;
        StateHasChanged();

        // await Http.PostAsJsonAsync("api/auth/send-otp", new { });

        await Task.Delay(3000);

        isSending = false;
        StateHasChanged();
    }
}
