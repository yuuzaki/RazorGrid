@page "/forgot-password"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject BlazorGrid.Services.QueryParamProtector Protector
@inject NavigationManager NavigationManager;
@implements IDisposable;
@using System.Security.Cryptography;

<div class="auth-card">
    <h1 class="app-title">AUTH APP</h1>

    @if (isVerifying)
    {
        <div class="slide-from-right text-center">
            <h2 class="section-title">Processing</h2>
            <div class="spinner"></div>
            @if (verifyResult)
            {
                <p>@((MarkupString)verifyLine1)</p>
                <p>@((MarkupString)verifyLine2)</p>
            }
            else
            {
                <p>Sending request <span class="dots"></span></p>
            }
        </div>
    } 
    else
    {
        <div class="slide-from-right">
            <h2 class="section-title">Forgot Password</h2>
            @if(!userNameValid){
                    <div class="field-wrapper">
                    <input type="text" id="cp-username" class="field-input"
                            placeholder=" " @bind="@username"
                            autocomplete="username" />
                    <label class="field-label" for="cp-username">Username</label>
                </div>
                
                <button class="auth-btn" disabled="@isVerifyLoading" @onclick="VerifyUsername">
                    @if (isVerifyLoading)
                    {
                        <span class="btn-spinner"></span>
                        @("Verifying...")
                    }
                    else
                    {
                        @("Verify")
                    }
                </button>
            }
            else{
                <div class="slide-from-top">
                    <EditForm Model="@optModel" OnValidSubmit="VerifyOTP" FormName="verifyOTP">
                        <div class="field-wrapper" style="margin-bottom:1.75rem;">
                            <input type="tel" inputmode="numeric"  maxlength="6"
                                id="otp-input" class="field-input field-input--otp"
                                placeholder=" " 
                                @bind="@otpValue"
                                autocomplete="one-time-code" />
                            <label class="field-label" for="otp-input">Enter OTP</label>
                        </div>
                        
                        <h2 class="section-title" style="text-align: right;">OTP Ref: @OTPRef</h2>
                        <button type="button" class="auth-btn" disabled="@(isSending || countdown > 0)" @onclick="SendOTPApi">
                            @if (isSending)
                            {
                                <span class="btn-spinner"></span>
                                @("Sending...")
                            }
                            else if (countdown > 0)
                            {
                                @($"...send again in {countdown}s")
                            }
                            else
                            {
                                @("Send OTP")
                            }
                        </button>

                        <button class="auth-btn" disabled="@isVerifyLoading" type="submit">
                            @if (isVerifyLoading)
                            {
                                <span class="btn-spinner"></span>
                                @("Verifying...")
                            }
                            else
                            {
                                @("Verify OTP")
                            }
                        </button>
                    </EditForm>
                </div>
            }
            <p class="text-center" style="margin:0;">
                <a href="/login" class="auth-link">Back to Login</a>
            </p>
        </div>
    }
</div>

@if (_toastMsg is not null)
{
    <div class="app-toast app-toast--@_toastType">
        <span>@_toastMsg</span>
        <button class="app-toast-close" @onclick="@(() => _toastMsg = null)">&times;</button>
    </div>
}

@code { 
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }
    public OTPModel optModel = new OTPModel();
    private string username = string.Empty;
    private string redirectUrl = "/";
    private string OTPRef = string.Empty;

    private string otpValue = string.Empty;
    private bool isSending = false;
    private bool isVerifyLoading = false;
    private int countdown = 0;

    
    private bool userNameValid = false;
    private bool tokenValid = false;
    private bool isVerifying = false;
    private bool verifyResult = false;
    private string verifyLine1 = string.Empty;
    private string verifyLine2 = string.Empty;

    private CancellationTokenSource _cts = new();
    private string? _toastMsg;
    private string _toastType = "error";
    private void ShowToast(string msg, string type = "error") { _toastMsg = msg; _toastType = type; }
   
    public class OTPModel
    {
        public string OTP { get; set; } = string.Empty;
    }
    private void OnOtpInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        otpValue = new string(raw.Where(char.IsDigit).Take(6).ToArray());
    }

    private async Task SendOTPApi()
    {
        @* if (string.IsNullOrWhiteSpace(otpValue) || otpValue.Length < 6)
        {
            ShowToast("Please enter a valid 6-digit OTP", "warning");
            return;
        } *@

        isSending = true;
        StateHasChanged();

        await Task.Delay(1500);

        string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        string result = "";

        for (int i = 0; i < 6; i++)
        {
            result += chars[RandomNumberGenerator.GetInt32(0, chars.Length)];
        }
        OTPRef = result;
        isSending = false;
        StateHasChanged();

        _ = RunCountdown(_cts.Token);
    }

    private async Task RunCountdown(CancellationToken ct)
{
    for (countdown = 20; countdown >= 1; countdown--)
    {
        if (ct.IsCancellationRequested) return; // ← bail out cleanly
        StateHasChanged();
        try
        {
            await Task.Delay(1000, ct); // ← also cancels the delay itself
        }
        catch (TaskCanceledException)
        {
            return; // ← expected, just exit
        }
    }
    countdown = 0;
    StateHasChanged();
}
    private void ClearToast() => _toastMsg = null;

    private async Task VerifyOTP()
    {
        ClearToast();
        
        isVerifyLoading = true;
        StateHasChanged();
        await Task.Yield();
        if (string.IsNullOrWhiteSpace(otpValue) || otpValue.Length < 6)
        {
            await Task.Delay(500);
            ShowToast("Please enter a valid 6-digit OTP", "warning");
            
            isVerifyLoading = false;
            return;
        }

        await Task.Delay(1300);
        isVerifyLoading = false;
        isVerifying = true;
        StateHasChanged();
        await Task.Yield();

        await Task.Delay(1500);

        if (otpValue == "666666")
        {
            verifyResult = true;
            verifyLine1 = "OTP verified successfully!";
            verifyLine2 = "Redirecting to login <span class=\"dots\"></span>";
            StateHasChanged();
            await Task.Delay(1500);
            NavigationManager.NavigateTo(redirectUrl);
        }
        else
        {
            isVerifying = false;
            ShowToast("Invalid OTP. Please try again.");
        }
    }
    private async Task VerifyUsername(){
        try{
            ClearToast();
            isVerifyLoading = true;
            await Task.Delay(1500);
            StateHasChanged();
            if(username.StartsWith("e")){
                ShowToast("Invalid username. Please try again.");
                isVerifyLoading = false;
            }
            else{
                isVerifyLoading = false;
                userNameValid = true;
                await SendOTPApi();
            }
        }
        catch(Exception ex){
            ShowToast("An error occurred. Please try again.");
            isVerifyLoading = false;
        }
    }
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
