<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="BlazorGrid.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" asp-append-version="true" />
    <link rel="stylesheet" href="app.css" asp-append-version="true" />
    <HeadOutlet />
</head>

<body>
    <Routes />

    <div id="components-reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-state-show">
                <div class="reconnect-spinner"></div>
                <h5 class="reconnect-title">Reconnecting&hellip;</h5>
                <p class="reconnect-message">Connection lost. Attempting to reconnect to the server.</p>
            </div>
            <div class="reconnect-state-failed">
                <div class="reconnect-icon reconnect-icon--error">&#x2715;</div>
                <h5 class="reconnect-title">Connection Failed</h5>
                <p class="reconnect-message">Could not reconnect after multiple attempts.</p>
                <button class="reconnect-btn" onclick="window.location.reload()">Reload Page</button>
            </div>
            <div class="reconnect-state-rejected">
                <div class="reconnect-icon reconnect-icon--warning">&#x26A0;</div>
                <h5 class="reconnect-title">Session Expired</h5>
                <p class="reconnect-message">Your session has expired. Please reload to continue.</p>
                <button class="reconnect-btn" onclick="window.location.reload()">Reload Page</button>
            </div>
        </div>
    </div>

    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 20,
                    retryIntervalMilliseconds: 3000,
                },
            },
        });
    </script>
</body>

</html>
